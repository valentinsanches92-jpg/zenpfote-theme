<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">
{{ 'zenpfote-v2.css' | asset_url | stylesheet_tag }}

<div class="zp2">

  <!-- ══════════════════════════════════════════
       NAV
  ══════════════════════════════════════════ -->
  <nav class="nav">
    <a href="{{ routes.root_url }}" class="nav-logo">🐾 <span>Zen</span>Pfote</a>
    <ul class="nav-links">
      <li><a href="{{ routes.root_url }}">Startseite</a></li>
      <li><a href="{{ routes.root_url }}#bewertungen">Bewertungen</a></li>
      <li><a href="{{ routes.root_url }}#faq">FAQ</a></li>
    </ul>
    <div class="nav-actions">
      <a href="{{ routes.root_url }}#produkt" class="nav-cart-btn">🛒 Jetzt kaufen</a>
      <button class="nav-hamburger" aria-label="Menü">☰</button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div class="mobile-menu" role="dialog" aria-modal="true">
    <div class="mobile-menu-panel">
      <button class="mobile-menu-close" aria-label="Schließen">✕</button>
      <a href="{{ routes.root_url }}" class="nav-logo">🐾 <span>Zen</span>Pfote</a>
      <ul class="mobile-nav-links">
        <li><a href="{{ routes.root_url }}">Startseite</a></li>
        <li><a href="{{ routes.root_url }}#wie-es-funktioniert">Wie es funktioniert</a></li>
        <li><a href="{{ routes.root_url }}#faq">FAQ</a></li>
        <li><a href="{{ routes.root_url }}#produkt">Jetzt kaufen →</a></li>
      </ul>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <div class="tracking-hero">
    <div class="container" style="position:relative;z-index:1;">
      <span class="eyebrow" style="color:var(--blue);">Bestellverfolgung</span>
      <h1 class="section-title" style="color:#fff;margin:0 auto;">Wo ist meine Bestellung?</h1>
      <p>Gib deine Bestellnummer und E-Mail-Adresse ein,<br>um den aktuellen Status deiner Lieferung zu sehen.</p>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       TRACKING FORM CARD
  ══════════════════════════════════════════ -->
  <div class="container" style="padding-bottom:64px;">
    <div class="tracking-form-card">
      <h3>🔍 Bestellung verfolgen</h3>
      <form id="zp-track-form" novalidate>
        <div class="form-group">
          <label class="form-label" for="zp-order">Bestellnummer</label>
          <input class="form-input" id="zp-order" type="text" placeholder="z.B. #ZP-12345" required>
          <p style="font-size:12px;color:var(--text-muted);margin-top:6px;">Die Bestellnummer findest du in deiner Bestätigungs-E-Mail.</p>
        </div>
        <div class="form-group">
          <label class="form-label" for="zp-email">E-Mail-Adresse</label>
          <input class="form-input" id="zp-email" type="email" placeholder="deine@email.de" required>
        </div>
        <button type="submit" class="btn-track">🔍 Bestellung verfolgen</button>
      </form>

      <!-- ══ TRACKING RESULT (shown after submit) ══ -->
      <div class="tracking-result" id="zp-tracking-result">
        <div style="background:var(--bg-light);border-radius:var(--r-md);padding:20px;margin-bottom:24px;border:1px solid var(--border);">
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
            <div>
              <p style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">BESTELLNUMMER</p>
              <p style="font-size:16px;font-weight:700;color:var(--navy);">#ZP-12345</p>
            </div>
            <div>
              <p style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">BESTELLDATUM</p>
              <p style="font-size:14px;font-weight:600;color:var(--navy);">20. April 2025</p>
            </div>
            <div>
              <p style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">STATUS</p>
              <span style="background:rgba(93,205,255,0.15);color:var(--blue-darker);font-size:12px;font-weight:700;padding:4px 12px;border-radius:var(--r-full);border:1px solid var(--border-md);">Unterwegs 🚚</span>
            </div>
          </div>
        </div>

        <!-- Tracking timeline -->
        <h4 style="font-size:15px;font-weight:700;color:var(--navy);margin-bottom:20px;">Sendungsverlauf</h4>
        <div class="tracking-steps">

          <div class="tracking-step">
            <div class="step-indicator">
              <div class="step-dot done">✓</div>
              <div class="step-line done"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Bestellung eingegangen</div>
              <div class="step-desc">Deine Bestellung wurde erfolgreich aufgegeben und bezahlt.</div>
              <div class="step-date">20. April 2025 · 14:23 Uhr</div>
            </div>
          </div>

          <div class="tracking-step">
            <div class="step-indicator">
              <div class="step-dot done">✓</div>
              <div class="step-line done"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Bestellung bestätigt &amp; verpackt</div>
              <div class="step-desc">Dein ZenPfote Paket wurde sorgfältig verpackt und für den Versand vorbereitet.</div>
              <div class="step-date">21. April 2025 · 09:15 Uhr</div>
            </div>
          </div>

          <div class="tracking-step">
            <div class="step-indicator">
              <div class="step-dot active">🚚</div>
              <div class="step-line pending"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Unterwegs zu dir</div>
              <div class="step-desc">Dein Paket ist auf dem Weg! Voraussichtliche Lieferung: <strong>23.–24. April 2025</strong></div>
              <div class="step-date" style="color:var(--blue-dark);">Aktueller Status · DHL Express</div>
            </div>
          </div>

          <div class="tracking-step">
            <div class="step-indicator">
              <div class="step-dot pending">4</div>
              <div class="step-line pending"></div>
            </div>
            <div class="step-content">
              <div class="step-title">Zustellung</div>
              <div class="step-desc">Dein Paket wird an deine Lieferadresse zugestellt.</div>
              <div class="step-date" style="color:var(--text-muted);">Voraussichtlich 23.–24. April 2025</div>
            </div>
          </div>

          <div class="tracking-step">
            <div class="step-indicator">
              <div class="step-dot pending">5</div>
            </div>
            <div class="step-content">
              <div class="step-title">Zugestellt ✓</div>
              <div class="step-desc">Paket erfolgreich zugestellt. Genieße deinen ZenPfote!</div>
              <div class="step-date" style="color:var(--text-muted);">Ausstehend</div>
            </div>
          </div>

        </div>

        <!-- DHL tracking link placeholder -->
        <div style="margin-top:24px;padding:16px;background:var(--bg-light);border-radius:var(--r-md);border:1px solid var(--border);text-align:center;">
          <p style="font-size:13px;color:var(--text-mid);margin-bottom:10px;">Trackingnummer: <strong style="color:var(--navy);">JD000299999999</strong></p>
          <a href="#" class="btn-secondary" style="font-size:14px;padding:10px 24px;">DHL Sendungsverfolgung öffnen →</a>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         INFO BOXES
    ══════════════════════════════════════════ -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px;">
      <div style="background:#fff;border:1px solid var(--border);border-radius:var(--r-md);padding:28px;text-align:center;">
        <div style="font-size:40px;margin-bottom:12px;">🚚</div>
        <h4 style="font-size:15px;font-weight:700;color:var(--navy);margin-bottom:8px;">Versanddauer</h4>
        <p style="font-size:14px;color:var(--text-mid);line-height:1.6;">DE: 1–3 Werktage<br>AT: 2–4 Werktage<br>CH: 3–5 Werktage</p>
      </div>
      <div style="background:#fff;border:1px solid var(--border);border-radius:var(--r-md);padding:28px;text-align:center;">
        <div style="font-size:40px;margin-bottom:12px;">🔄</div>
        <h4 style="font-size:15px;font-weight:700;color:var(--navy);margin-bottom:8px;">60-Tage-Garantie</h4>
        <p style="font-size:14px;color:var(--text-mid);line-height:1.6;">Nicht zufrieden? Einfach melden – wir erstatten den vollen Betrag.</p>
      </div>
      <div style="background:#fff;border:1px solid var(--border);border-radius:var(--r-md);padding:28px;text-align:center;">
        <div style="font-size:40px;margin-bottom:12px;">💬</div>
        <h4 style="font-size:15px;font-weight:700;color:var(--navy);margin-bottom:8px;">Kundensupport</h4>
        <p style="font-size:14px;color:var(--text-mid);line-height:1.6;">Mo–Fr 9–18 Uhr<br><a href="mailto:support@zenpfote.de" style="color:var(--blue-dark);">support@zenpfote.de</a></p>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         FAQ TRACKING
    ══════════════════════════════════════════ -->
    <div style="margin-top:64px;">
      <h2 class="section-title" style="text-align:center;margin-bottom:32px;">Häufige Fragen zur Lieferung</h2>
      <div class="faq-list" style="margin-top:0;">
        <div class="faq-item">
          <button class="faq-q">Wie lange dauert die Lieferung? <span class="faq-arrow">+</span></button>
          <div class="faq-a">Innerhalb Deutschlands dauert die Lieferung 1–3 Werktage. Nach Österreich 2–4 Werktage und in die Schweiz 3–5 Werktage.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Wie verfolge ich meine Sendung? <span class="faq-arrow">+</span></button>
          <div class="faq-a">Sobald dein Paket versandt wurde, erhältst du eine E-Mail mit deiner DHL-Trackingnummer. Du kannst die Sendung auch oben auf dieser Seite verfolgen.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Ich habe keine Bestätigungs-E-Mail erhalten. Was soll ich tun? <span class="faq-arrow">+</span></button>
          <div class="faq-a">Bitte prüfe deinen Spam-Ordner. Wenn die E-Mail dort nicht ist, schreib uns an support@zenpfote.de mit deiner Bestellnummer.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Mein Paket wurde nicht zugestellt. Was jetzt? <span class="faq-arrow">+</span></button>
          <div class="faq-a">Bitte kontaktiere uns innerhalb von 30 Tagen nach dem Versanddatum. Wir werden das Problem schnell lösen und dein Paket neu versenden oder erstatten.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Kann ich meine Lieferadresse nach dem Kauf ändern? <span class="faq-arrow">+</span></button>
          <div class="faq-a">Eine Adressänderung ist nur möglich, wenn das Paket noch nicht versandt wurde. Bitte kontaktiere uns sofort unter support@zenpfote.de.</div>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         CTA — ORDER AGAIN
    ══════════════════════════════════════════ -->
    <div style="background:var(--bg-light);border-radius:var(--r-lg);padding:48px;text-align:center;margin-top:64px;border:1px solid var(--border);">
      <div style="font-size:48px;margin-bottom:16px;">🐾</div>
      <h3 style="font-family:'DM Serif Display',serif;font-size:26px;color:var(--navy);margin-bottom:12px;">Deinem Hund gefällt ZenPfote?</h3>
      <p style="font-size:16px;color:var(--text-mid);margin-bottom:28px;">Hole dir ein zweites Exemplar für Freunde oder Familie mit Hund – und spare gleich 45%.</p>
      <a href="{{ routes.root_url }}#produkt" class="btn-primary" style="font-size:16px;padding:18px 40px;">Nochmal bestellen — 45% Rabatt →</a>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════ -->
  <footer class="site-footer" style="margin-top:0;">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo">🐾 <span>Zen</span>Pfote</div>
          <p>Der rotierende Leckerball, der deinen Hund durch Biologie beruhigt – ohne Chemie, ohne Risiko.</p>
          <p class="footer-copy">© 2025 ZenPfote. Alle Rechte vorbehalten.</p>
        </div>
        <div class="footer-col">
          <h4>Shop</h4>
          <a href="{{ routes.root_url }}">Startseite</a>
          <a href="{{ routes.root_url }}#produkt">ZenPfote Pup Bowl</a>
          <a href="/pages/bestellung-verfolgen">Bestellung verfolgen</a>
        </div>
        <div class="footer-col">
          <h4>Hilfe</h4>
          <a href="/pages/kontakt">Kontakt</a>
          <a href="/pages/versand">Versandinformationen</a>
          <a href="{{ routes.root_url }}policies/refund-policy">Rückgabe &amp; Erstattung</a>
          <a href="{{ routes.root_url }}#faq">FAQ</a>
        </div>
        <div class="footer-col">
          <h4>Rechtliches</h4>
          <a href="{{ routes.root_url }}policies/privacy-policy">Datenschutzerklärung</a>
          <a href="{{ routes.root_url }}policies/terms-of-service">AGB</a>
          <a href="/pages/impressum">Impressum</a>
          <a href="{{ routes.root_url }}policies/refund-policy">Widerrufsrecht</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div style="font-size:12px;color:rgba(255,255,255,0.35);">Sicher &amp; verschlüsselt bezahlen:</div>
        <div class="footer-pay">
          <span class="pay-pill">PayPal</span><span class="pay-pill">Klarna</span><span class="pay-pill">SOFORT</span>
          <span class="pay-pill">Visa</span><span class="pay-pill">Mastercard</span><span class="pay-pill">Apple Pay</span>
        </div>
      </div>
    </div>
  </footer>

</div>

<script src="{{ 'zenpfote-v2.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "ZenPfote Bestellverfolgung",
  "tag": "div",
  "class": "zenpfote-tracking-v2",
  "settings": []
}
{% endschema %}
